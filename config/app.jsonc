                            },
                            {
                                "type": "Health",
                                "maxHealth": 35.0
                            },
                            {
                                "type": "Collider",
                                "layer": "enemy",
                                "shape": "Capsule",
                                "worldSpace": true,
                                "radius": 0.6,
                                "height": 1.8,
                                "centerOffset": [0.0, 0.9, 0.0]
                            },
                            {
                                "type": "Weapon",
                                "cooldown": 1.8,
                                "bulletSpeed": 22.0,
                                "bulletDamage": 8.0,
                                "bulletLifetime": 4.0,
                                "bulletScale": 0.2,
                                "muzzleOffset": [0.0, 0.0, -0.8],
                                "fireSound": "gunshot-enemy"
                            }
                        ]
                    }
                ]
            }
        },
        "world": [
            {
                "name": "Player Camera",
                "position": [0.0, 1.8, 14.0],
                "components": [
                    {
                        "type": "Camera",
                        "fovY": 60,
                        "near": 0.1,
                        "far": 500.0
                    },
                    {
                        "type": "Free Camera Controller",
                        "baseRotationSensitivity": 0.003,
                        "aimSensitivityMultiplier": 0.5,
                        "aimFovY": 30,
                        "aimSpeed": 8.0
                    },
                    {
                        "type": "PlayerMovement",
                        "walkSpeed": 8.0,
                        "sprintMultiplier": 2.0,

                                "attackDamage": 10.0,
                                "attackCooldown": 0.3,
                                "scoreValue": 100
                            },
                            {
                                "type": "Health",
                                "maxHealth": 60.0
                            },
                            {
                                "type": "Collider",
                                "layer": "enemy",
                                "shape": "Capsule",
                                "worldSpace": true,
                                "radius": 0.8,
                                "height": 3.0,
                                "centerOffset": [0.0, 1.5, 0.0]
                            }
                        ]
                    },
                    {
                        "name": "Drone",
                        "model": "drone",
                        "rotation": [0.0, 0.0, 0.0],
                        "scale": [0.008, 0.008, 0.008],
                        "components": [
                            {
                                "type": "Enemy",
                                "enemyType": "Flyer",
                                "moveSpeed": 3.4,
                                "turnSpeed": 6.0,
                                "aggroRange": 120.0,
                                "attackRange": 12.0,
                                "preferredDistance": 9.0,
                                "attackDamage": 8.0,
                                "attackCooldown": 2.0,
                                "hoverFrequency": 2.3,
                                "hoverAmplitude": 0.4,
                                "baseHeight": 5.0,

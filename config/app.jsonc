                    {
                        "type": "Player",
                        "currentAmmo": 30,
                        "maxAmmo": 120
                    },
                    {
                        "type": "Health",
                        "maxHealth": 100.0
                    },
                    {
                        "type": "Collider",
                        "layer": "player",
                        "radius": 0.45,
                        "height": 1.8,
                        "shape": "Capsule"
                    },
                    {
                        "type": "Weapon",
                        "cooldown": 0.18,
                        "bulletSpeed": 100.0,
                        "bulletDamage": 20.0,
                        "bulletLifetime": 2.5,
                        "bulletScale": 0.12,
                        "muzzleOffset": [0.45, -0.45, -2.0],
                        "fireSound": "gunshot-player",
                        "reloadSound": "reload",
                        "reloadTime": 1.0
                    },
                    {
                        "type": "Post Process Effects Component"
                    }
                ],
                "children": [
                    {
                        "position": [1, -1, -2],
                        "rotation": [0, 0, 0],
                        "scale": [0.3, 0.3, 0.3],
                        "components": [
                            {
                                "type": "Model Renderer",
                                "model": "gun",
                                "firstPersonOverlay": true
                            }
                        ],
                        "children": [
                            {
                                "position": [0, 0, 0],
                                "components": [
                                    {
                                        "type": "light",
                                        "lightType": "spot",
                                        "color": [1, 0.8, 0.6],
                                        "attenuation": [1.0, 0.14, 0.07],
                                        "spotAngles": [15, 20]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            },
            {
                "name": "map",
                "position": [0, 0, 0],
                "components": [
                    {
                        "type": "Model Renderer",
                        "model": "map"
                    },
                    {
                        "type": "Collider",
                        "layer": "environment",
                        "shape": "Model",
                        "model": "map"
